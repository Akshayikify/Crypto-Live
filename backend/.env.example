# .env.example — Copy this to .env and fill in your values.
# NEVER commit .env to source control.
#
# For Render deployment, set these as Environment Variables in the
# Render dashboard (Services → Your Service → Environment).

# ── Django ──────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=<generate-a-long-random-string>
DJANGO_DEBUG=False
# Comma-separated list of allowed hostnames (no https://)
ALLOWED_HOSTS=cryptolive-backend.onrender.com,localhost,127.0.0.1

# ── Database ─────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<AppName>

# ── Redis ────────────────────────────────────────────────────────────────────
# Render Redis URL (or external, e.g. Upstash)
REDIS_URL=redis://localhost:6379/0

# ── CORS ─────────────────────────────────────────────────────────────────────
# Set to False in production; list your Vercel frontend URL below
CORS_ALLOW_ALL_ORIGINS=False
# Comma-separated list of allowed origins (include https://)
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# ── Clerk Authentication ──────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com -> API Keys
CLERK_PUBLISHABLE_KEY=<your-clerk-publishable-key>
CLERK_SECRET_KEY=<your-clerk-secret-key>

# ── Sentiment Analysis ────────────────────────────────────────────────────────
HF_API_KEY=<your-huggingface-api-key>
CRYPTOPANIC_API_KEY=<your-cryptopanic-api-key>
NEWS_API_KEY=<your-newsapi-key>
